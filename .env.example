WISP_ENV=dev
WISP_DB_URL=sqlite+aiosqlite:///./wisp.db
WISP_HTTP_TIMEOUT=12
WISP_USER_AGENT=WISPBot/0.1 (+https://localhost)
WISP_CACHE_TTL_SECONDS=900
WISP_ENABLE_EMBEDDINGS=false
WISP_LOG_LEVEL=INFO
WISP_API_KEYS=

# ── Optional LLM synthesis (Qwen3-8B) ─────────────────────────────────────────
# Set WISP_LLM_ENABLED=true and point BASE_URL at an OpenAI-compatible endpoint.
# When false (default) the LlmSynthesisClient is never instantiated and all
# /research requests follow the native extractive path unchanged.
#
# Serving options:
#   vLLM (recommended):  vllm serve Qwen/Qwen3-8B --port 8001 --api-key dev-token
#   Ollama (simpler):    ollama pull qwen3:8b && ollama serve
#                        → set WISP_LLM_BASE_URL=http://localhost:11434/v1
WISP_LLM_ENABLED=false
WISP_LLM_BASE_URL=http://localhost:8001/v1
WISP_LLM_API_KEY=dev-token
WISP_LLM_MODEL=Qwen/Qwen3-8B

# Latency budgets — tighten after measuring p95 on your hardware
WISP_LLM_TIMEOUT_SECONDS=8.0
WISP_LLM_TIMEOUT_CONCISE_SECONDS=5.0
WISP_LLM_TIMEOUT_REPORT_SECONDS=12.0
WISP_LLM_TIMEOUT_STRUCTURED_SECONDS=10.0

# Quality / scope
WISP_LLM_MAX_TOKENS=900
WISP_LLM_TEMPERATURE=0.2
WISP_LLM_MAX_CONTEXT_EVIDENCE=6

# Qwen3 thinking mode — increases latency and JSON instability; off by default
WISP_LLM_ENABLE_THINKING=false

# Gate behaviour — auto lets the evidence profile decide; never/always override
WISP_LLM_SYNTHESIS_MODE_DEFAULT=auto

# Gate thresholds — tune empirically using wisp_llm_gate_total Prometheus metric
WISP_LLM_GATE_CLEAR_WINNER_MARGIN=0.12
WISP_LLM_GATE_CLEAR_WINNER_RATIO=1.25
WISP_LLM_GATE_MIN_CONFIDENCE=0.40
WISP_LLM_GATE_REPORT_MIN_CONFIDENCE=0.45
WISP_LLM_GATE_SYNTHESIS_INTENT_THRESHOLD=0.10
